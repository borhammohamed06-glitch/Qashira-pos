                                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total}" Width="120" />
                                        <DataGridTextColumn Header="الربح" Binding="{Binding Profit}" Width="110" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Text="{Binding AuditDetailLinesMessage}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />

                                <TextBlock Text="العمليات المرتبطة"
                                           Style="{StaticResource SectionTitleText}"
                                           Margin="0,18,0,8" />
                                <DataGrid ItemsSource="{Binding AuditDetailTimeline}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Height="260"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
