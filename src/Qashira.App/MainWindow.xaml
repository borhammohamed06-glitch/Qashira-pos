                                        <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="165" />
                                        <DataGridTextColumn Header="العملية" Binding="{Binding ActionName}" Width="150" />
                                        <DataGridTextColumn Header="التفاصيل" Binding="{Binding Description}" Width="650" />
