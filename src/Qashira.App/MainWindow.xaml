                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="من تاريخ" Style="{StaticResource FieldLabelText}" />
                                    <DatePicker SelectedDate="{Binding InvoiceHistoryFromDateValue, UpdateSourceTrigger=PropertyChanged}"
                                                Height="42"
                                                FontSize="16"
                                                Language="ar-EG"
                                                FlowDirection="RightToLeft" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="إلى تاريخ" Style="{StaticResource FieldLabelText}" />
                                    <DatePicker SelectedDate="{Binding InvoiceHistoryToDateValue, UpdateSourceTrigger=PropertyChanged}"
                                                Height="42"
                                                FontSize="16"
                                                Language="ar-EG"
                                                FlowDirection="RightToLeft" />
                                </StackPanel>

                                <DockPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0">
                                    <Button DockPanel.Dock="Left"
                                            Content="بحث"
                                            Command="{Binding LoadInvoiceHistoryCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0" />
                                    <TextBox Text="{Binding InvoiceHistorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputTextBoxStyle}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding LoadInvoiceHistoryCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </DockPanel>

                                <UniformGrid Grid.Row="2" Grid.ColumnSpan="3" Columns="3" Margin="0,12,0,0">
                                    <Button Content="اليوم"
                                            Command="{Binding InvoiceHistoryTodayCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="0,0,6,0" />
                                    <Button Content="الأسبوع"
                                            Command="{Binding InvoiceHistoryWeekCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="3,0,3,0" />
                                    <Button Content="الشهر"
                                            Command="{Binding InvoiceHistoryMonthCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="6,0,0,0" />
                                </UniformGrid>
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding InvoiceHistoryItems}"
                                      SelectedItem="{Binding SelectedInvoiceHistoryItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      Margin="0,16,0,0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="150" />
                                    <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="145" />
                                    <DataGridTextColumn Header="الكاشير" Binding="{Binding CashierName}" Width="130" />
                                    <DataGridTextColumn Header="الأصناف" Binding="{Binding ItemCount}" Width="75" />
                                    <DataGridTextColumn Header="الصافي" Binding="{Binding NetAmount, StringFormat={}{0:0.00}}" Width="90" />
                                    <DataGridTextColumn Header="مرتجع" Binding="{Binding ReturnedAmount, StringFormat={}{0:0.00}}" Width="90" />
                                    <DataGridTextColumn Header="الحالة" Binding="{Binding StatusName}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="2"
                                       Text="{Binding InvoiceHistoryMessage}"
                                       Foreground="{StaticResource ErrorBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SurfacePanelStyle}" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="تفاصيل الفاتورة" Style="{StaticResource SectionTitleText}" />
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding InvoiceHistorySummary}"
                                               FontSize="17"
                                               LineHeight="29"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="بنود الفاتورة" Style="{StaticResource FieldLabelText}" Margin="0,16,0,0" />
                                    <DataGrid ItemsSource="{Binding InvoiceHistoryLines}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              FlowDirection="RightToLeft"
                                              Height="210"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="الصنف" Binding="{Binding ItemName}" Width="*" MinWidth="150" />
                                            <DataGridTextColumn Header="مباع" Binding="{Binding SoldQuantity}" Width="60" />
                                            <DataGridTextColumn Header="مرتجع" Binding="{Binding ReturnedQuantity}" Width="70" />
                                            <DataGridTextColumn Header="متبقي" Binding="{Binding RemainingQuantity}" Width="70" />
                                            <DataGridTextColumn Header="السعر" Binding="{Binding UnitPrice, StringFormat={}{0:0.00}}" Width="75" />
                                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding LineTotal, StringFormat={}{0:0.00}}" Width="85" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock Text="عمليات المرتجع" Style="{StaticResource FieldLabelText}" Margin="0,16,0,0" />
                                    <DataGrid ItemsSource="{Binding InvoiceHistoryReturns}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              FlowDirection="RightToLeft"
                                              Height="170"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="135" />
                                            <DataGridTextColumn Header="المستخدم" Binding="{Binding UserName}" Width="105" />
                                            <DataGridTextColumn Header="القيمة" Binding="{Binding Amount, StringFormat={}{0:0.00}}" Width="75" />
                                            <DataGridTextColumn Header="السبب" Binding="{Binding Reason}" Width="*" MinWidth="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </ScrollViewer>

                            <Button Grid.Row="2"
                                    Content="طباعة الفاتورة المحددة"
                                    Command="{Binding PrintSelectedInvoiceHistoryCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,14,0,0" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding ShiftVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="الشيفت وتقفيل اليومية" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="راجع المبلغ المتوقع في الدرج، ثم أدخل النقد الفعلي لإغلاق الشيفت." Style="{StaticResource MutedText}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}" Margin="0,0,12,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="ملخص الشيفت الحالي" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="{Binding ShiftSummaryText}"
                                       FontSize="20"
                                       LineHeight="34"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0" />
                        </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource SurfacePanelStyle}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Top"
                            MaxHeight="260">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="إغلاق الشيفت" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="النقد الفعلي في الدرج" Style="{StaticResource FieldLabelText}" />
                            <TextBox Text="{Binding ClosingCash, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            <TextBlock Text="{Binding CloseShiftMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,16,0,0" />
                            <Button Content="إغلاق الشيفت"
                                    Command="{Binding CloseShiftCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,18,0,0" />
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding ReturnsVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="المرتجعات" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="ابحث برقم الفاتورة، ثم اختر الكميات المطلوب إرجاعها. إرجاع المنتجات يعيد المخزون ويسجل حركة مخزون." Style="{StaticResource MutedText}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="0.7*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,10">
                                <Button DockPanel.Dock="Left" Content="بحث" Command="{Binding FindInvoiceForReturnCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" />
                                <TextBox Text="{Binding ReturnInvoiceNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         FlowDirection="LeftToRight"
                                         TextAlignment="Right">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding FindInvoiceForReturnCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                            </DockPanel>

                            <TextBlock Grid.Row="1" Text="{Binding ReturnInvoiceSummary}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />

                            <StackPanel Grid.Row="2" Visibility="{Binding PossibleReturnInvoicesVisibility}" Margin="0,0,0,8">
                                <TextBlock Text="فواتير محتملة" Style="{StaticResource FieldLabelText}" />
                                <DataGrid ItemsSource="{Binding PossibleReturnInvoices}"
                                          SelectedItem="{Binding SelectedPossibleReturnInvoice}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          MaxHeight="120"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="*" />
                                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding NetAmount, StringFormat={}{0:0.00}}" Width="90" />
                                        <DataGridTextColumn Header="التاريخ" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="140" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button Content="فتح الفاتورة المحددة"
                                        Command="{Binding SelectPossibleReturnInvoiceCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,0" />
                            </StackPanel>

                            <DataGrid Grid.Row="3"
                                      ItemsSource="{Binding ReturnItems}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      HeadersVisibility="Column"
                                      FlowDirection="RightToLeft"
                                      MinHeight="180"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الصنف" Binding="{Binding ItemName}" Width="220" MinWidth="180" IsReadOnly="True" />
                                    <DataGridTextColumn Header="المباع" Binding="{Binding SoldQuantity}" Width="80" IsReadOnly="True" />
                                    <DataGridTextColumn Header="مرتجع سابق" Binding="{Binding AlreadyReturnedQuantity}" Width="105" IsReadOnly="True" />
                                    <DataGridTextColumn Header="المتاح" Binding="{Binding ReturnableQuantity}" Width="80" IsReadOnly="True" />
                                    <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding UnitPrice, StringFormat={}{0:0.00}}" Width="95" IsReadOnly="True" />
                                    <DataGridTemplateColumn Header="كمية الإرجاع" Width="115">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ReturnQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="32"
                                                         FontSize="16"
                                                         TextAlignment="Center"
                                                         FlowDirection="LeftToRight"
                                                         VerticalContentAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="إجمالي المرتجع" Binding="{Binding ReturnTotal, StringFormat={}{0:0.00}}" Width="115" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="4"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Background="#F8FBFA"
                                    Padding="10"
                                    Margin="0,10,0,0">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="{Binding ReturnTotalText}"
                                               Style="{StaticResource SectionTitleText}"
                                               Margin="0,0,0,0"
                                               VerticalAlignment="Center" />
                                    <WrapPanel DockPanel.Dock="Left" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Button Content="حفظ المرتجع" Command="{Binding SaveReturnCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" MinWidth="140" />
                                        <Button Content="إرجاع كل المتاح" Command="{Binding ReturnAllItemsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" MinWidth="130" />
                                        <Button Content="طباعة الفاتورة" Command="{Binding PrintReturnInvoiceCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" MinWidth="130" />
                                    </WrapPanel>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource SurfacePanelStyle}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Top"
                            MinWidth="260"
                            MaxHeight="320">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="بيانات المرتجع" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="سبب الإرجاع" Style="{StaticResource FieldLabelText}" />
                            <TextBox Text="{Binding ReturnReason, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                      MinHeight="72"
                                      MaxHeight="120"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True" />
                            <TextBlock Text="{Binding ReturnMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,10,0,0" />
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="PosWorkspaceRoot" Visibility="{Binding PosVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="240" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="الكاشير" Style="{StaticResource PageTitleText}" />
                        <TextBlock Text="ابحث بالاسم أو الباركود، ثم أضف المنتج للفاتورة." Style="{StaticResource MutedText}" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Border Style="{StaticResource TotalPanelStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="الإجمالي" Style="{StaticResource TotalLabelText}" />
                                    <TextBlock Text="{Binding CartTotalText}" Style="{StaticResource TotalValueText}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        x:Name="NotificationBellButton"
                                        Command="{Binding ToggleNotificationsCommand}"
                                        Style="{StaticResource NotificationBellButtonStyle}"
                                        ToolTip="تنبيهات المخزون">
                                    <Grid Width="42" Height="42">
                                        <Viewbox Width="24"
                                                 Height="24"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Path Fill="White"
                                                  Data="M12,22 C13.1,22 14,21.1 14,20 L10,20 C10,21.1 10.9,22 12,22 Z M4,18 L20,18 L18,15 L18,9 C18,5.7 15.3,3 12,3 C8.7,3 6,5.7 6,9 L6,15 L4,18 Z" />
                                        </Viewbox>
                                        <Border Visibility="{Binding LowStockBadgeVisibility}"
                                                Background="#D92D20"
                                                CornerRadius="10"
                                                MinWidth="20"
                                                Height="20"
                                                Padding="4,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding LowStockCount}"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>

                        <Popup IsOpen="{Binding IsNotificationsPopupOpen}"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=NotificationBellButton}"
                               AllowsTransparency="True"
                               StaysOpen="False"
                               FlowDirection="RightToLeft">
                            <Border Background="White"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Width="330"
                                    MaxHeight="360">
                                <StackPanel>
                                    <TextBlock Text="تنبيهات المخزون" Style="{StaticResource FieldLabelText}" />
                                    <TextBlock Text="لا توجد منتجات تحت حد التنبيه."
                                               Visibility="{Binding LowStockEmptyVisibility}"
                                               Style="{StaticResource MutedText}" />
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  MaxHeight="290">
                                        <ItemsControl ItemsSource="{Binding LowStockNotifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="0,8">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding ProductName}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="15"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock FontSize="13"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       TextWrapping="Wrap">
                                                                <Run Text="المتاح: " />
                                                                <Run Text="{Binding CurrentQuantity, Mode=OneWay}" />
                                                                <Run Text=" | حد التنبيه: " />
                                                                <Run Text="{Binding Threshold, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="بحث المنتجات" Style="{StaticResource SectionTitleText}" />
                            <DockPanel Grid.Row="1" Margin="0,0,0,14">
                                <Button DockPanel.Dock="Left" Content="بحث / إضافة" Command="{Binding SearchOrAddProductCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" />
                                <TextBox x:Name="PosSearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         KeyDown="PosSearchBox_OnKeyDown" />
                            </DockPanel>

                            <ListBox Grid.Row="2"
                                     x:Name="ProductResultsListBox"
                                     ItemsSource="{Binding Products}"
                                     SelectedItem="{Binding SelectedProduct}"
                                     SelectionMode="Extended"
                                     BorderThickness="0"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     SelectionChanged="ProductResultsListBox_OnSelectionChanged"
                                     MouseDoubleClick="ProductResultsListBox_OnMouseDoubleClick"
                                     KeyDown="ProductResultsListBox_OnKeyDown">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"
                                                   FlowDirection="RightToLeft" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="Width" Value="238" />
                                        <Setter Property="Margin" Value="6" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                    <Border x:Name="CardChrome"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CardChrome" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#E8F3F0" />
                                                            <Setter TargetName="CardChrome" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border MinHeight="112" Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <CheckBox Grid.Row="0"
                                                      Width="34"
                                                      Height="34"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Top"
                                                      IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=TwoWay}" />

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Name}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="52"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,40,8" />

                                            <DockPanel Grid.Row="2" LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding Barcode}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="132"
                                                           FlowDirection="LeftToRight" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text=" | "
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="13" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding SalePrice, StringFormat={}{0:0.00} ج.م}"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold" />
                                            </DockPanel>
                                        </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="3" Margin="0,18,0,0">
                                <Button Content="إضافة للفاتورة" Command="{Binding AddSelectedProductCommand}" Style="{StaticResource PrimaryButtonStyle}" />

                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12" Margin="0,14,0,0" CornerRadius="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="خدمات الطباعة" Style="{StaticResource FieldLabelText}" />
                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding CashierPrintingTemplates}"
                                                 SelectedItem="{Binding SelectedCashierPrintingTemplate}"
                                                 BorderThickness="0"
                                                 MaxHeight="138"
                                                 Margin="0,8,0,10"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel IsItemsHost="True" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="{x:Type ListBoxItem}">
                                                    <Setter Property="Margin" Value="4" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                                <Border x:Name="ServiceCard"
                                                                        Background="#F8FBFA"
                                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="10">
                                                                    <ContentPresenter />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="ServiceCard" Property="Background" Value="#E5F2EF" />
                                                                        <Setter TargetName="ServiceCard" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ServiceCard" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Width="142">
                                                        <TextBlock Text="{Binding ServiceName}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="44" />
                                                        <TextBlock Text="{Binding PriceText}" Foreground="{StaticResource PrimaryBrush}" FontSize="13" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="118" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding CashierPrintingServiceQuantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" ToolTip="الكمية" />
                                            <Button Grid.Column="2" Content="إضافة خدمة" Command="{Binding AddPrintingTemplateToCartCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12" Margin="0,14,0,0" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="خدمة طباعة / تصوير" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding PrintServiceName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding PrintPages, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" ToolTip="عدد الصفحات" />
                                            <TextBox Grid.Column="2" Text="{Binding PrintCopies, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" ToolTip="عدد النسخ" />
                                            <TextBox Grid.Column="4" Text="{Binding PrintPricePerPage, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" ToolTip="سعر الصفحة" />
                                        </Grid>
                                        <Button Content="إضافة خدمة" Command="{Binding AddPrintServiceCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SurfacePanelStyle}" Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="120" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="الفاتورة الحالية" Style="{StaticResource SectionTitleText}" Margin="0,0,0,8" />

                            <DataGrid Grid.Row="1"
                                      x:Name="CartLinesDataGrid"
                                      ItemsSource="{Binding CartLines}"
                                              SelectedItem="{Binding SelectedCartLine}"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              IsReadOnly="False"
                                              MinHeight="120"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                            <DataGridTextColumn Header="الصنف" Binding="{Binding Name}" Width="*" IsReadOnly="True" />
                                            <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                            <DataGridTextColumn Header="السعر" Binding="{Binding UnitPrice, StringFormat={}{0:0.00}}" Width="90" IsReadOnly="True" />
                                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding Total, StringFormat={}{0:0.00}}" Width="100" IsReadOnly="True" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                <Grid Grid.Row="2" Margin="0,8,0,6" Visibility="{Binding DiscountVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="خصم الفاتورة" Style="{StaticResource FieldLabelText}" />
                                        <TextBlock Text="{Binding DiscountPreviewText}" Style="{StaticResource MutedText}" FontSize="13" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             ToolTip="{Binding DiscountValueLabel}" />
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding DiscountTypes}"
                                              SelectedItem="{Binding SelectedDiscountType}"
                                              Height="44"
                                              FontSize="15"
                                              Padding="8,4" />
                                </Grid>
                                <TextBlock Grid.Row="3" Text="{Binding PosMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,2,0,4" />
                                <WrapPanel Grid.Row="4" HorizontalAlignment="Left" Margin="0,2,0,0">
                                    <Button Content="حذف الصنف المحدد" Command="{Binding RemoveSelectedCartLineCommand}" Style="{StaticResource DangerButtonStyle}" Margin="6,0,0,6" MinWidth="128" />
                                    <Button Content="تعليق الفاتورة" Command="{Binding HoldInvoiceCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,6" MinWidth="112" />
                                    <Button Content="حفظ البيع نقداً" Command="{Binding CompleteSaleCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,6" MinWidth="118" />
                                    <Button Content="حفظ وطباعة" Command="{Binding CompleteSaleAndPrintCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="6,0,0,6" MinWidth="118" />
                                    <Button Content="إعادة طباعة آخر فاتورة" Command="{Binding PrintLastReceiptCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,6" MinWidth="150" />
                                </WrapPanel>
                                <Border Grid.Row="5" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,4,0,0">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <Button DockPanel.Dock="Left"
                                                    Content="تحديث"
                                                    Command="{Binding RefreshSuspendedInvoicesCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    MinWidth="90"
                                                    Margin="8,0,0,0" />
                                            <TextBlock Text="الفواتير المعلقة" Style="{StaticResource FieldLabelText}" VerticalAlignment="Center" />
                                        </DockPanel>
                                        <DataGrid x:Name="SuspendedInvoicesGrid"
                                                  ItemsSource="{Binding SuspendedInvoices}"
                                                  SelectedItem="{Binding SelectedSuspendedInvoice}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  Height="160"
                                                  Margin="0,8,0,8"
                                                  KeyDown="SuspendedInvoicesGrid_OnKeyDown"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="الرقم" Binding="{Binding HoldNumber}" Width="110" />
                                                <DataGridTextColumn Header="الأصناف" Binding="{Binding ItemCount}" Width="70" />
                                                <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, StringFormat={}{0:0.00}}" Width="90" />
                                                <DataGridTextColumn Header="الوقت" Binding="{Binding CreatedAt, StringFormat={}{0:HH:mm}}" Width="70" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Content="استرجاع"
                                                    Command="{Binding ResumeSuspendedInvoiceCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}" />
                                            <Button Grid.Column="2"
                                                    Content="إلغاء"
                                                    Command="{Binding CancelSuspendedInvoiceCommand}"
                                                    Style="{StaticResource DangerButtonStyle}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Popup IsOpen="{Binding IsQuickNavigationOpen, Mode=TwoWay}"
               Placement="Center"
               AllowsTransparency="True"
               StaysOpen="False"
               FlowDirection="RightToLeft">
            <Border Width="460"
                    MaxHeight="520"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="بحث سريع عن شاشة"
                               Style="{StaticResource SectionTitleText}"
                               Margin="0,0,0,10" />
                    <TextBox x:Name="QuickNavigationSearchBox"
                             Grid.Row="1"
                             Text="{Binding QuickNavigationSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}"
                             ToolTip="اكتب اسم الشاشة ثم اضغط Enter" />
                    <ListBox x:Name="QuickNavigationResultsListBox"
                             Grid.Row="2"
                             ItemsSource="{Binding QuickNavigationResults}"
                             SelectedItem="{Binding SelectedQuickNavigationItem}"
                             DisplayMemberPath="Title"
                             MinHeight="160"
                             MaxHeight="360"
                             Margin="0,10,0,0"
                             FontSize="16"
                             KeyDown="QuickNavigationResultsListBox_OnKeyDown"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
