                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="قائمة المستخدمين" Style="{StaticResource SectionTitleText}" />
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Users}"
                                      SelectedItem="{Binding SelectedUser}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الاسم" Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="اسم الدخول" Binding="{Binding Username}" Width="130" />
                                    <DataGridTextColumn Header="الدور" Binding="{Binding RoleName}" Width="120" />
                                    <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive}" Width="70" />
