                                        <DataGridTextColumn Header="البند" Binding="{Binding Label}" Width="190" />
                                        <DataGridTextColumn Header="القيمة" Binding="{Binding Value}" Width="680" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="بنود العملية"
