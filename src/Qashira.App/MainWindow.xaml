<Window x:Class="Qashira.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:Qashira.App.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource App_Title}"
        Width="1080"
        Height="680"
        MinWidth="820"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        Language="ar-EG"
        Icon="Assets/qashira-icon.ico"
        FontFamily="{StaticResource AppFontFamily}"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <services:SidebarActiveBackgroundConverter x:Key="SidebarActiveBackgroundConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" Padding="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <Image Source="Assets/qashira-logo.png"
                           Width="64"
                           Height="64"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"
                           Stretch="Uniform" />
                    <TextBlock Text="{DynamicResource App_Title}" Style="{StaticResource SidebarTitleText}" />
                    <TextBlock Text="{DynamicResource App_Subtitle}" Style="{StaticResource SidebarMutedText}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                    <TextBlock Text="{Binding SessionText}" Style="{StaticResource SidebarMutedText}" />
                </StackPanel>

                <ScrollViewer Margin="0,10,0,0"
                              Visibility="{Binding NavigationVisibility}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Expander Header="الكاشير" IsExpanded="True" Foreground="White" Margin="0,0,0,6">
                            <StackPanel Margin="0,6,0,0">
                                <Button Content="الكاشير" Command="{Binding ShowPosCommand}" IsEnabled="{Binding CanOpenPos}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=POS}" />
                                <Button Content="الفواتير" Command="{Binding ShowInvoiceHistoryCommand}" IsEnabled="{Binding CanOpenInvoiceHistory}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=InvoiceHistory}" Margin="0,6,0,0" />
                                <Button Content="المرتجعات" Command="{Binding ShowReturnsCommand}" IsEnabled="{Binding CanOpenReturns}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Returns}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="المنتجات والمخزون" IsExpanded="True" Foreground="White" Margin="0,0,0,6">
                            <StackPanel Margin="0,6,0,0">
                                <Button Content="المنتجات" Command="{Binding ShowProductsCommand}" IsEnabled="{Binding CanOpenProducts}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Products}" />
                                <Button Content="التصنيفات" Command="{Binding ShowCategoriesCommand}" IsEnabled="{Binding CanOpenCategories}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Categories}" Margin="0,6,0,0" />
                                <Button Content="الباركود (قيد التطوير)" Command="{Binding ShowBarcodeCommand}" IsEnabled="{Binding CanOpenBarcode}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Barcode}" Margin="0,6,0,0" />
                                <Button Content="المخزون والتنبيهات" Command="{Binding ShowInventoryCommand}" IsEnabled="{Binding CanOpenInventory}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Inventory}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="خدمات الطباعة" IsExpanded="True" Foreground="White" Margin="0,0,0,6">
                            <StackPanel Margin="0,6,0,0">
                                <Button Content="خدمات الطباعة" Command="{Binding ShowPrintingServicesCommand}" IsEnabled="{Binding CanOpenPrintingServices}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=PrintingServices}" />
                                <Button Content="خامات الطباعة (قيد التطوير)" Command="{Binding ShowPrintingMaterialsCommand}" IsEnabled="{Binding CanOpenPrintingMaterials}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=PrintingMaterials}" Margin="0,6,0,0" />
                                <Button Content="الإنتاج (قيد التطوير)" Command="{Binding ShowProductionCommand}" IsEnabled="{Binding CanOpenProduction}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Production}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="التقارير" IsExpanded="True" Foreground="White" Margin="0,0,0,6">
                            <StackPanel Margin="0,6,0,0">
                                <Button Content="تقارير المبيعات" Command="{Binding ShowReportsCommand}" IsEnabled="{Binding CanOpenReports}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Reports}" />
                                <Button Content="تقارير الأرباح (قيد التطوير)" Command="{Binding ShowProfitReportsCommand}" IsEnabled="{Binding CanOpenProfitReports}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=ProfitReports}" Margin="0,6,0,0" />
                                <Button Content="تقارير الشيفت" Command="{Binding ShowShiftCommand}" IsEnabled="{Binding CanOpenShift}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Shift}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="الإدارة" IsExpanded="True" Foreground="White" Margin="0,0,0,6">
                            <StackPanel Margin="0,6,0,0">
                                <Button Content="المستخدمون والصلاحيات" Command="{Binding ShowUsersCommand}" IsEnabled="{Binding CanOpenUsers}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Users}" />
                                <Button Content="سجل التدقيق" Command="{Binding ShowAuditLogsCommand}" IsEnabled="{Binding CanOpenAuditLogs}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=AuditLogs}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="الإعدادات" IsExpanded="True" Foreground="White">
                            <StackPanel Margin="0,6,0,0">
                                <Button Content="إعدادات النظام" Command="{Binding ShowSystemSettingsCommand}" IsEnabled="{Binding CanOpenSystemSettings}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=SystemSettings}" />
                                <Button Content="إعدادات الطباعة" Command="{Binding ShowPrinterSettingsCommand}" IsEnabled="{Binding CanOpenPrinterSettings}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=PrinterSettings}" Margin="0,6,0,0" />
                                <Button Content="النسخ الاحتياطي" Command="{Binding ShowBackupCommand}" IsEnabled="{Binding CanOpenBackup}" Style="{StaticResource SidebarButtonStyle}" Background="{Binding ActiveWorkspace, Converter={StaticResource SidebarActiveBackgroundConverter}, ConverterParameter=Backup}" Margin="0,6,0,0" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="12" ClipToBounds="True">
            <Border Style="{StaticResource SurfacePanelStyle}"
                    MaxWidth="460"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Visibility="{Binding LoginVisibility}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Image Source="Assets/qashira-logo.png"
                           Width="96"
                           Height="96"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Stretch="Uniform" />
                    <TextBlock Text="{DynamicResource Login_Title}" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="{DynamicResource Login_Hint}" Style="{StaticResource MutedText}" Margin="0,6,0,22" />

                    <TextBlock Text="{DynamicResource Username}" Style="{StaticResource FieldLabelText}" />
                    <TextBox x:Name="UsernameTextBox" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Text="{DynamicResource Password}" Style="{StaticResource FieldLabelText}" Margin="0,14,0,0" />
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource InputPasswordBoxStyle}" PasswordChanged="PasswordBox_OnPasswordChanged" />

                    <TextBlock Text="{Binding LoginMessage}" Foreground="{StaticResource ErrorBrush}" Margin="0,12,0,0" TextWrapping="Wrap" />
                    <Button Content="{DynamicResource Login_Button}" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,22,0,0" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Style="{StaticResource SurfacePanelStyle}"
                    MaxWidth="460"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Visibility="{Binding ChangePasswordVisibility}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Image Source="Assets/qashira-logo.png"
                           Width="84"
                           Height="84"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Stretch="Uniform" />
                    <TextBlock Text="تغيير كلمة المرور" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="يجب تعيين كلمة مرور قوية قبل استخدام النظام." Style="{StaticResource MutedText}" Margin="0,6,0,22" />

                    <TextBlock Text="كلمة المرور الجديدة" Style="{StaticResource FieldLabelText}" />
                    <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource InputPasswordBoxStyle}" PasswordChanged="NewPasswordBox_OnPasswordChanged" />

                    <TextBlock Text="تأكيد كلمة المرور" Style="{StaticResource FieldLabelText}" Margin="0,14,0,0" />
                    <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource InputPasswordBoxStyle}" PasswordChanged="ConfirmPasswordBox_OnPasswordChanged" />

                    <TextBlock Text="{Binding PasswordChangeMessage}" Foreground="{StaticResource ErrorBrush}" Margin="0,12,0,0" TextWrapping="Wrap" />
                    <Button Content="حفظ كلمة المرور" Command="{Binding ChangeRequiredPasswordCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,22,0,0" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Style="{StaticResource SurfacePanelStyle}"
                    MaxWidth="420"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Visibility="{Binding OpenShiftVisibility}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="فتح شيفت جديد" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="أدخل المبلغ الموجود في الدرج عند بداية الشيفت." Style="{StaticResource MutedText}" Margin="0,6,0,22" />

                    <TextBlock Text="رصيد بداية الشيفت" Style="{StaticResource FieldLabelText}" />
                    <TextBox x:Name="OpeningCashTextBox" Text="{Binding OpeningCash, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                    <TextBlock Text="{Binding ShiftMessage}" Foreground="{StaticResource ErrorBrush}" Margin="0,12,0,0" TextWrapping="Wrap" />
                    <Button Content="فتح الشيفت" Command="{Binding OpenShiftCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,22,0,0" />
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Visibility="{Binding ProductManagementVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="إدارة المنتجات والباركود" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="أضف المنتجات بكود داخلي تلقائي وباركود فريد، مع حفظ اسم بحث عربي تلقائياً." Style="{StaticResource MutedText}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,14">
                                <Button DockPanel.Dock="Left" Content="بحث" Command="{Binding SearchManagedProductsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" />
                                <CheckBox DockPanel.Dock="Left"
                                          Content="عرض الموقوفة"
                                          IsChecked="{Binding ShowInactiveProducts}"
                                          VerticalAlignment="Center"
                                          FontSize="15"
                                          Margin="8,0,0,0" />
                                <TextBox Text="{Binding ManagedProductsSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            </DockPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ManagedProducts}"
                                      SelectedItem="{Binding SelectedManagedProduct}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="الباركود" Binding="{Binding Barcode}" Width="135" />
                                    <DataGridTextColumn Header="البيع" Binding="{Binding SalePrice, StringFormat={}{0:0.00}}" Width="80" />
                                    <DataGridTextColumn Header="المخزون" Binding="{Binding StockQuantity}" Width="80" />
                                    <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive}" Width="65" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2" Margin="0,16,0,0">
                                <WrapPanel HorizontalAlignment="Left">
                                    <Button Content="منتج جديد" Command="{Binding NewProductCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button Content="تعديل المحدد" Command="{Binding EditSelectedProductCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" />
                                    <Button Content="تفعيل / إيقاف" Command="{Binding ToggleProductActiveCommand}" Style="{StaticResource DangerButtonStyle}" Margin="8,0,0,0" IsEnabled="{Binding CanToggleManagedProductActive}" />
                                    <Button Content="استيراد Excel" Command="{Binding ImportProductsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" />
                                    <Button Content="تصدير Excel" Command="{Binding ExportProductsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" />
                                </WrapPanel>

                                <DockPanel Margin="0,10,0,0" HorizontalAlignment="Left">
                                    <Button DockPanel.Dock="Left"
                                            Content="طباعة باركود المحدد"
                                            Command="{Binding PrintSelectedProductBarcodeCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="170"
                                            Margin="8,0,0,0" />
                                    <TextBox Text="{Binding BarcodeLabelQuantity, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             Width="90"
                                             ToolTip="عدد الليبلات" />
                                </DockPanel>
                                <TextBlock Text="{Binding ProductMessage}"
                                           Foreground="{StaticResource ErrorBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SurfacePanelStyle}" Margin="12,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="بيانات المنتج" Style="{StaticResource SectionTitleText}" />

                                <TextBlock Text="اسم المنتج" Style="{StaticResource FieldLabelText}" />
                                <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="التصنيف" Style="{StaticResource FieldLabelText}" Margin="0,12,0,8" />
                                <ComboBox ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding SelectedCategory}"
                                          DisplayMemberPath="Name"
                                          Height="42" />
                                <TextBlock Text="{Binding SelectedCategoryUnitText}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />

                                <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        Padding="10"
                                        Margin="0,12,0,0"
                                        CornerRadius="8"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="إضافة تصنيف جديد" Style="{StaticResource FieldLabelText}" />
                                        <DockPanel Margin="0,8,0,0">
                                            <Button DockPanel.Dock="Left"
                                                    Content="إضافة"
                                                    Command="{Binding SaveCategoryCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Margin="8,0,0,0"
                                                    MinWidth="90" />
                                            <TextBox Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding CategoryMessage}"
                                                   Foreground="{StaticResource ErrorBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="الباركود" Style="{StaticResource FieldLabelText}" Margin="0,12,0,8" />
                                <TextBox Text="{Binding ProductBarcode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="الكود الداخلي" Style="{StaticResource FieldLabelText}" Margin="0,12,0,8" />
                                <TextBox Text="{Binding ProductInternalCode, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         IsReadOnly="True"
                                         ToolTip="يتم إنشاء الكود الداخلي تلقائياً ولا يتم إدخاله يدوياً." />

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ProductPurchasePriceLabel}" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding ProductPurchasePrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" IsEnabled="{Binding CanEditProductPrice}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding ProductSalePriceLabel}" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding ProductSalePrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" IsEnabled="{Binding CanEditProductPrice}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,12,0,0" Visibility="{Binding DirectQuantityVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ProductStockQuantityLabel}" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding ProductStockQuantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" IsEnabled="{Binding CanEditProductStock}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="حد التنبيه" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding ProductLowStockThreshold, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" IsEnabled="{Binding CanEditProductStock}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,12,0,0" Visibility="{Binding PackageQuantityVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding PackageCountLabel}" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding ProductPackageCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" IsEnabled="{Binding CanEditProductStock}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding UnitsPerPackageLabel}" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding ProductUnitsPerPackage, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" IsEnabled="{Binding CanEditProductStock}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding ComputedProductStockQuantityText}"
                                           Style="{StaticResource MutedText}"
                                           Visibility="{Binding PackageQuantityVisibility}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />

                                <Grid Margin="0,12,0,0" Visibility="{Binding PackageQuantityVisibility}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="حد التنبيه بالقطع" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding ProductLowStockThreshold, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" IsEnabled="{Binding CanEditProductStock}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding ProductMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,14,0,0" />
                                <Button Content="حفظ المنتج" Command="{Binding SaveProductCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,18,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding BarcodeVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="الباركود" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="شاشة مستقلة لطباعة وإدارة ملصقات الباركود." Style="{StaticResource MutedText}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource SurfacePanelStyle}"
                        MaxWidth="680"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="28">
                    <StackPanel>
                        <TextBlock Text="هذه الشاشة قيد التطوير" Style="{StaticResource SectionTitleText}" TextAlignment="Center" />
                        <TextBlock Text="لن يتم فتح شاشة المنتجات من هذا المسار. سيتم تخصيص هذه الشاشة لطباعة الباركود كمسار مستقل." Style="{StaticResource MutedText}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Visibility="{Binding PrintingServicesVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="إدارة خدمات الطباعة" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="اضبط خدمات الطباعة والتصوير والتجليد التي تظهر مباشرة في شاشة الكاشير." Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.25*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="قائمة خدمات الطباعة" Style="{StaticResource SectionTitleText}" />

                            <Grid Grid.Row="0" Margin="0,44,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding PrintingServiceSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" ToolTip="بحث باسم الخدمة" />
                                <Button Grid.Column="2" Content="بحث" Command="{Binding SearchPrintingServicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding PrintingServiceTemplates}"
                                      SelectedItem="{Binding SelectedPrintingServiceTemplate}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الخدمة" Binding="{Binding ServiceName}" Width="*" />
                                    <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="80" />
                                    <DataGridTextColumn Header="السعر" Binding="{Binding SellingPricePerUnit, StringFormat={}{0:0.00}}" Width="90" />
                                    <DataGridTextColumn Header="الكاشير" Binding="{Binding CashierVisibilityText}" Width="130" />
                                    <DataGridTextColumn Header="الحالة" Binding="{Binding StatusText}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <WrapPanel Grid.Row="2" HorizontalAlignment="Left" Margin="0,12,0,0">
                                <CheckBox Content="إظهار المتوقف" IsChecked="{Binding ShowInactivePrintingServices}" VerticalAlignment="Center" Margin="10,0,0,8" />
                                <Button Content="تحديث" Command="{Binding SearchPrintingServicesCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,8" MinWidth="90" />
                                <Button Content="جديد" Command="{Binding NewPrintingServiceTemplateCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,8" MinWidth="90" />
                                <Button Content="تعديل المحدد" Command="{Binding EditSelectedPrintingServiceTemplateCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="6,0,0,8" MinWidth="110" />
                                <Button Content="تفعيل / إيقاف" Command="{Binding TogglePrintingServiceTemplateActiveCommand}" IsEnabled="{Binding CanTogglePrintingServiceTemplateActive}" Style="{StaticResource DangerButtonStyle}" Margin="6,0,0,8" MinWidth="120" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SurfacePanelStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="بيانات الخدمة" Style="{StaticResource SectionTitleText}" />

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="اسم الخدمة" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding PrintingServiceName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="اسم الوحدة" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding PrintingServiceUnitName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" ToolTip="صفحة / ورقة / نسخة / متر" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="سعر البيع للوحدة" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding PrintingServiceSellingPricePerUnit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="اختصار اختياري" Style="{StaticResource FieldLabelText}" />
                                        <TextBox Text="{Binding PrintingServiceShortcutKey, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                    </StackPanel>
                                </Grid>

                                <WrapPanel Margin="0,12,0,0">
                                    <CheckBox Content="يظهر في الكاشير" IsChecked="{Binding PrintingServiceShowInCashier}" Margin="14,0,0,8" />
                                    <CheckBox Content="نشط" IsChecked="{Binding PrintingServiceIsActive}" Margin="14,0,0,8" />
                                </WrapPanel>

                                <TextBlock Text="الخامات المستهلكة" Style="{StaticResource SectionTitleText}" Margin="0,20,0,0" />
                                <TextBlock Text="أضف الخامات التي تُخصم تلقائياً عند بيع هذه الخدمة مثل ورق A4 أو غلاف أو سلك. اتركها فارغة للخدمات التي لا تستهلك خامات." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding PrintingMaterialProducts}"
                                              SelectedItem="{Binding SelectedPrintingMaterialProduct}"
                                              DisplayMemberPath="DisplayText"
                                              Height="44" />
                                    <TextBox Grid.Column="2" Text="{Binding PrintingMaterialQuantityPerUnit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" ToolTip="الاستهلاك لكل وحدة" />
                                    <TextBox Grid.Column="4" Text="{Binding PrintingMaterialNotes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" ToolTip="ملاحظات" />
                                    <Button Grid.Column="6" Content="إضافة" Command="{Binding AddPrintingMaterialCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </Grid>

                                <DataGrid ItemsSource="{Binding PrintingTemplateMaterials}"
                                          SelectedItem="{Binding SelectedPrintingTemplateMaterial}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column"
                                          Height="150"
                                          Margin="0,10,0,0"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="الخامة" Binding="{Binding ProductName}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="المتاح" Binding="{Binding DisplayStockText}" Width="90" IsReadOnly="True" />
                                        <DataGridTextColumn Header="استهلاك/وحدة" Binding="{Binding QuantityPerUnit, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="150" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Button Content="حذف الخامة المحددة" Command="{Binding RemovePrintingMaterialCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,10,0,0" />

                                <TextBlock Text="ملاحظات" Style="{StaticResource FieldLabelText}" Margin="0,14,0,0" />
                                <TextBox Text="{Binding PrintingServiceNotes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" MinHeight="70" TextWrapping="Wrap" AcceptsReturn="True" />

                                <TextBlock Text="{Binding PrintingServiceMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,12,0,0" />
                                <Button Content="حفظ خدمة الطباعة" Command="{Binding SavePrintingServiceTemplateCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,14,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding InventoryVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="250" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="المخزون والتنبيهات" Style="{StaticResource PageTitleText}" />
                        <TextBlock Text="تعديل المخزون يسجل حركة مخزون وسجل تدقيق، والتنبيهات لا تتكرر لنفس المنتج." Style="{StaticResource MutedText}" />
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource WarningPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="تنبيهات المخزون" Style="{StaticResource TotalLabelText}" />
                            <TextBlock Text="{Binding LowStockCount}" Style="{StaticResource TotalValueText}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,10">
                                <Button DockPanel.Dock="Left" Content="بحث" Command="{Binding SearchInventoryCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" />
                                <TextBox Text="{Binding InventorySearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            </DockPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding InventoryProducts}"
                                      SelectedItem="{Binding SelectedInventoryProduct}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="المنتج" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="المخزون" Binding="{Binding StockQuantity}" Width="80" />
                                    <DataGridTextColumn Header="حد التنبيه" Binding="{Binding LowStockThreshold}" Width="90" />
                                    <DataGridCheckBoxColumn Header="منخفض" Binding="{Binding IsLowStock}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2" Margin="0,16,0,0">
                                <TextBlock Text="الكمية الجديدة" Style="{StaticResource FieldLabelText}" />
                                <TextBox Text="{Binding NewStockQuantity, UpdateSourceTrigger=PropertyChanged}"
                                         InputScope="Number"
                                         Style="{StaticResource InputTextBoxStyle}" />
                                <TextBlock Text="سبب التعديل" Style="{StaticResource FieldLabelText}" Margin="0,12,0,8" />
                                <TextBox Text="{Binding StockAdjustmentReason, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                                <TextBlock Text="{Binding InventoryMessage}" Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,12,0,0" />
                                <Button Content="تعديل المخزون" Command="{Binding AdjustStockCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,16,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1" Margin="12,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.95*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="1.05*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource SurfacePanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="تنبيهات المخزون المنخفض" Style="{StaticResource SectionTitleText}" />
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding LowStockNotifications}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*" />
                                        <DataGridTextColumn Header="الحالي" Binding="{Binding CurrentQuantity}" Width="70" />
                                        <DataGridTextColumn Header="الحد" Binding="{Binding Threshold}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource SurfacePanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="آخر حركات المخزون" Style="{StaticResource SectionTitleText}" />
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding StockMovements}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*" />
                                        <DataGridTextColumn Header="النوع" Binding="{Binding MovementTypeName}" Width="110" />
                                        <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="70" />
                                        <DataGridTextColumn Header="قبل" Binding="{Binding OldQuantity}" Width="60" />
                                        <DataGridTextColumn Header="بعد" Binding="{Binding NewQuantity}" Width="60" />
                                        <DataGridTextColumn Header="المرجع" Binding="{Binding ReferenceName}" Width="100" />
                                        <DataGridTextColumn Header="الوقت" Binding="{Binding CreatedAtText}" Width="125" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding PrinterSettingsVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="إعدادات الطباعة" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="اختر طابعة الإيصالات ثم اختبر الطباعة قبل الاستخدام اليومي." Style="{StaticResource MutedText}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource SurfacePanelStyle}"
                        MaxWidth="560"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Margin="0,18,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="طابعة الإيصالات" Style="{StaticResource SectionTitleText}" />
                        <Button Content="تحديث قائمة الطابعات"
                                Command="{Binding RefreshPrintersCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"
                                MinWidth="160"
                                Margin="0,0,0,10" />
                        <ComboBox ItemsSource="{Binding InstalledPrinters}"
                                  SelectedItem="{Binding SelectedReceiptPrinterName, UpdateSourceTrigger=PropertyChanged}"
                                  Height="42"
                                  FontSize="16" />

                        <TextBlock Text="{Binding PrinterSettingsSummary}"
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />

                        <TextBlock Text="اسم المحل على الإيصال" Style="{StaticResource FieldLabelText}" Margin="0,14,0,0" />
                        <TextBox Text="{Binding ReceiptStoreName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                        <TextBlock Text="عنوان الإيصال" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                        <TextBox Text="{Binding ReceiptTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                        <TextBlock Text="ذيل الإيصال" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                        <TextBox Text="{Binding ReceiptFooter, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                        <TextBlock Text="مقاس ورق الإيصال" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                        <ComboBox ItemsSource="{Binding ReceiptPaperWidths}"
                                  SelectedItem="{Binding ReceiptPaperWidth, UpdateSourceTrigger=PropertyChanged}"
                                  Height="42"
                                  FontSize="16" />

                        <TextBlock Text="طابعة الباركود والليبلات" Style="{StaticResource FieldLabelText}" Margin="0,14,0,0" />
                        <ComboBox ItemsSource="{Binding InstalledPrinters}"
                                  SelectedItem="{Binding SelectedLabelPrinterName, UpdateSourceTrigger=PropertyChanged}"
                                  Height="42"
                                  FontSize="16" />

                        <TextBlock Text="مقاس ليبل الباركود" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                        <ComboBox ItemsSource="{Binding BarcodeLabelSizes}"
                                  SelectedItem="{Binding BarcodeLabelSize, UpdateSourceTrigger=PropertyChanged}"
                                  Height="42"
                                  FontSize="16" />

                        <TextBlock Text="ملف طابعة الباركود" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                        <ComboBox ItemsSource="{Binding BarcodePrinterProfiles}"
                                  SelectedItem="{Binding BarcodePrinterProfile, UpdateSourceTrigger=PropertyChanged}"
                                  Height="42"
                                  FontSize="16"
                                  ToolTip="Auto يختار TSPL أو ZPL عند التعرف على الطابعة، وWindowsDriver يبقي الطباعة بالطريقة القديمة." />

                        <TextBlock Text="فاصل الليبل بالمليمتر" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                        <TextBox Text="{Binding BarcodeLabelGapMm, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 ToolTip="اتركه 2 مم لمعظم رولات الليبل ذات الفاصل." />

                        <TextBlock Text="معايرة الباركود أفقياً بالمليمتر" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                        <TextBox Text="{Binding BarcodeHorizontalOffsetMm, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 ToolTip="اكتب 0 للوضع الافتراضي. السالب يحرك الباركود لليسار، والموجب يحركه لليمين." />

                        <TextBlock Text="معايرة الباركود رأسياً بالمليمتر" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                        <TextBox Text="{Binding BarcodeVerticalOffsetMm, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 ToolTip="اكتب 0 للوضع الافتراضي. السالب يحرك الباركود لأعلى، والموجب يحركه لأسفل." />

                        <WrapPanel HorizontalAlignment="Left" Margin="0,18,0,0">
                            <Button Content="حفظ الإعدادات"
                                    Command="{Binding SavePrinterSettingsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    MinWidth="150" />
                            <Button Content="اختبار الإيصال"
                                    Command="{Binding TestReceiptPrinterCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0"
                                    MinWidth="150" />
                            <Button Content="اختبار الباركود"
                                    Command="{Binding TestBarcodeLabelPrinterCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="8,0,0,0"
                                    MinWidth="150" />
                        </WrapPanel>

                        <TextBlock Text="{Binding PrinterSettingsMessage}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,16,0,0" />
                    </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Visibility="{Binding SystemSettingsVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="إعدادات النظام" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="إعدادات عامة تتحكم في سلوك البيع والمخزون والقيم الافتراضية داخل النظام." Style="{StaticResource MutedText}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="بيانات المكتبة" Style="{StaticResource SectionTitleText}" />

                                <TextBlock Text="اسم المكتبة" Style="{StaticResource FieldLabelText}" />
                                <TextBox Text="{Binding SystemStoreName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="العملة" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                                <TextBox Text="{Binding SystemCurrency, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="حد تنبيه المخزون الافتراضي" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                                <TextBox Text="{Binding SystemLowStockThreshold, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="سلوك الكاشير" Style="{StaticResource SectionTitleText}" Margin="0,22,0,8" />
                                <CheckBox Content="السماح بالبيع حتى لو المخزون غير كاف"
                                          IsChecked="{Binding SystemAllowNegativeStock, UpdateSourceTrigger=PropertyChanged}"
                                          FontSize="16"
                                          Margin="0,4,0,0" />
                                <CheckBox Content="تفعيل الخصومات في شاشة الكاشير"
                                          IsChecked="{Binding SystemDiscountsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                          FontSize="16"
                                          Margin="0,10,0,0" />

                                <Button Content="حفظ إعدادات النظام"
                                        Command="{Binding SaveSystemSettingsCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,22,0,0"
                                        MinWidth="180"
                                        HorizontalAlignment="Left" />

                                <TextBlock Text="{Binding SystemSettingsMessage}"
                                           Foreground="{StaticResource ErrorBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,16,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </Grid>

            <Grid Visibility="{Binding CategoryManagementVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="التصنيفات" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="إدارة تصنيفات المنتجات ووحدات القياس بعيداً عن إعدادات النظام." Style="{StaticResource MutedText}" />
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource SurfacePanelStyle}" Margin="0,18,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="إدارة التصنيفات" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="أضف التصنيف وحدد وحدة القياس الافتراضية التي تتحكم في حقول شاشة المنتجات." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,14" />
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="اسم التصنيف" Style="{StaticResource FieldLabelText}" />
                                <TextBox Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="وحدة القياس" Style="{StaticResource FieldLabelText}" />
                                <ComboBox ItemsSource="{Binding CategoryMeasurementUnits}"
                                          SelectedItem="{Binding SelectedCategoryMeasurementUnit}"
                                          DisplayMemberPath="Name"
                                          Height="42" />
                            </StackPanel>
                        </Grid>

                        <CheckBox Grid.Row="2"
                                  Content="نشط"
                                  IsChecked="{Binding CategoryIsActive, UpdateSourceTrigger=PropertyChanged}"
                                  FontSize="16"
                                  HorizontalAlignment="Left"
                                  Margin="0,10,0,10" />

                        <DataGrid Grid.Row="3"
                                  ItemsSource="{Binding ManagedCategories}"
                                  SelectedItem="{Binding SelectedManagedCategory}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="التصنيف" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="الوحدة" Binding="{Binding MeasurementUnitText}" Width="110" />
                                <DataGridTextColumn Header="المنتجات" Binding="{Binding ProductCount}" Width="95" />
                                <DataGridTextColumn Header="الحالة" Binding="{Binding StatusText}" Width="95" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="4" Margin="0,14,0,0">
                            <WrapPanel HorizontalAlignment="Left">
                                <Button Content="تصنيف جديد"
                                        Command="{Binding NewCategoryCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="120" />
                                <Button Content="حفظ التصنيف"
                                        Command="{Binding SaveCategoryCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        MinWidth="130" />
                                <Button Content="تعديل المحدد"
                                        Command="{Binding EditSelectedCategoryCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0"
                                        MinWidth="120" />
                                <Button Content="تفعيل / إيقاف"
                                        Command="{Binding ToggleCategoryActiveCommand}"
                                        IsEnabled="{Binding CanToggleManagedCategoryActive}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Margin="8,0,0,0"
                                        MinWidth="130" />
                            </WrapPanel>

                            <TextBlock Text="{Binding CategoryMessage}"
                                       Foreground="{StaticResource ErrorBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding PrintingMaterialsVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="خامات الطباعة" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="شاشة مستقلة لخامات التشغيل مثل الورق والغلاف والسلك والرولات." Style="{StaticResource MutedText}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource SurfacePanelStyle}"
                        MaxWidth="680"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="28">
                    <StackPanel>
                        <TextBlock Text="هذه الشاشة قيد التطوير" Style="{StaticResource SectionTitleText}" TextAlignment="Center" />
