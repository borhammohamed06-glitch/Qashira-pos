                                <Button Content="تفعيل / إيقاف" Command="{Binding ToggleUserActiveCommand}" Style="{StaticResource DangerButtonStyle}" Margin="8,0,0,0" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource SurfacePanelStyle}" Margin="12,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="بيانات المستخدم" Style="{StaticResource SectionTitleText}" />

                            <TextBlock Text="الاسم بالكامل" Style="{StaticResource FieldLabelText}" />
                            <TextBox Text="{Binding UserFullName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                            <TextBlock Text="اسم الدخول" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                            <TextBox Text="{Binding UserUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />

                            <TextBlock Text="كلمة المرور" Style="{StaticResource FieldLabelText}" Margin="0,12,0,0" />
                            <TextBox Text="{Binding UserPassword, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="اتركها فارغة أثناء التعديل إذا لم ترد تغيير كلمة المرور." />

                            <TextBlock Text="الدور" Style="{StaticResource FieldLabelText}" Margin="0,12,0,8" />
                            <ComboBox ItemsSource="{Binding UserRoles}"
                                      SelectedItem="{Binding SelectedUserRole}"
                                      DisplayMemberPath="DisplayName"
                                      Height="42" />

                            <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="0,1,0,0"
                                    Margin="0,16,0,14" />

                            <TextBlock Text="صلاحيات المستخدم" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="حدد الصلاحيات المسموحة لهذا المستخدم. الدور يحمّل قالباً مبدئياً فقط." Style="{StaticResource MutedText}" Margin="0,0,0,10" />

                            <StackPanel Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding UserPermissions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsGranted, UpdateSourceTrigger=PropertyChanged}"
                                                      FontSize="15"
                                                      Margin="0,0,0,8" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <TextBlock Text="{Binding PermissionMessage}"
                                       Foreground="{StaticResource ErrorBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />

                            <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="0,1,0,0"
                                    Margin="0,16,0,14" />

                            <CheckBox Content="الحساب نشط"
                                      IsChecked="{Binding UserIsActive}"
                                      Margin="0,14,0,0"
                                      FontSize="16" />

                            <Button Content="حفظ المستخدم"
                                    Command="{Binding SaveUserCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,18,0,0" />

                            <TextBlock Text="{Binding UserMessage}"
                                       Foreground="{StaticResource ErrorBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,14,0,0" />
                        </StackPanel>
