                                    Command="{Binding ImportBackupCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,12,0,0" />
                            <Button Content="تصدير النسخة المحددة"
                                    Command="{Binding ExportSelectedBackupCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,12,0,0" />
                            <Button Content="حذف النسخة المحددة"
                                    Command="{Binding DeleteSelectedBackupCommand}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Margin="0,12,0,0" />
